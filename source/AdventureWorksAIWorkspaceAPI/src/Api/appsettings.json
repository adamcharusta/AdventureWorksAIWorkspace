{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Wolverine": "Information"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "AdventureWorksAIWorkspaceAPI.Api"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "AdventureWorksAIWorkspaceDatabase": ""
  },
  "Identity": {
    "InitialAdmin": {
      "Enabled": true,
      "UserName": "admin",
      "Email": "admin@adventureworksai.local",
      "TemplatePassword": ""
    },
    "Jwt": {
      "Issuer": "AdventureWorksAIWorkspaceAPI",
      "Audience": "AdventureWorksAIWorkspaceGUI",
      "SigningKey": "",
      "AccessTokenLifetimeMinutes": 60,
      "RefreshTokenLifetimeDays": 7
    }
  }
}
