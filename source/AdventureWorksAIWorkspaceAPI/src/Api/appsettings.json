{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Wolverine": "Information"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "AdventureWorksAIWorkspaceAPI.Api"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "AdventureWorksAIWorkspaceDatabase": "Server=localhost,1433;Database=AdventureWorksAIWorkspace;User Id=sa;Password=ChangeThis_StrongPassword_123!;Encrypt=True;TrustServerCertificate=True;",
    "AdventureWorksDatabase": "Server=localhost,1433;Database=AdventureWorks2025;User Id=sa;Password=ChangeThis_StrongPassword_123!;Encrypt=True;TrustServerCertificate=True;ApplicationIntent=ReadOnly;"
  },
  "AdventureWorks": {
    "CommandTimeoutSeconds": 30,
    "MaxRows": 1000
  },
  "OpenAi": {
    "ApiKey": "",
    "Model": "gpt-4o",
    "TimeoutSeconds": 100
  },
  "Identity": {
    "InitialAdmin": {
      "Enabled": true,
      "UserName": "admin",
      "Email": "admin@adventureworksai.local",
      "TemplatePassword": "zaq1@WSX"
    },
    "Jwt": {
      "Issuer": "AdventureWorksAIWorkspaceAPI",
      "Audience": "AdventureWorksAIWorkspaceGUI",
      "SigningKey": "ExampleDevelopmentJwtSigningKey_ChangeMe_AtLeast32Chars_2026!",
      "AccessTokenLifetimeMinutes": 60,
      "RefreshTokenLifetimeDays": 7
    }
  }
}
