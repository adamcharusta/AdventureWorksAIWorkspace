MSSQL_SA_PASSWORD=ChangeThis_StrongPassword_123!
MSSQL_PORT=1433
API_PORT=5159
WEB_PORT=5173
SEQ_PORT=5341
SEQ_FIRSTRUN_NOAUTHENTICATION=true
ASPNETCORE_ENVIRONMENT=Development

INITIAL_ADMIN_ENABLED=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@adventureworksai.local
INITIAL_ADMIN_PASSWORD=ChangeThis_AdminPassword_123!

JWT_SIGNING_KEY=ChangeThis_LocalJwtSigningKey_WithAtLeast32Characters_123!
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# OpenAI. Required to generate or refine reports through the AI chat. Viewing the seeded
# sample report works without a key. Get a key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=100
# Optional: point at an OpenAI-compatible endpoint. Leave empty for the default OpenAI API.
# OPENAI_BASE_URL=

# AdventureWorks read-only query guardrails.
ADVENTUREWORKS_COMMAND_TIMEOUT_SECONDS=30
ADVENTUREWORKS_MAX_ROWS=1000

ADVENTUREWORKS_DATABASE=AdventureWorks2025
ADVENTUREWORKS_BACKUP_URL=https://github.com/Microsoft/sql-server-samples/releases/download/adventureworks/AdventureWorks2025.bak
ADVENTUREWORKS_BACKUP_FILE=AdventureWorks2025.bak

# Least-privilege, read-only login the application uses for AdventureWorks. The init job creates
# this login (db_datareader + DENY on writes) so AI-generated SQL can never modify AdventureWorks.
ADVENTUREWORKS_READER_USER=awreader
ADVENTUREWORKS_READER_PASSWORD=ChangeThis_ReadOnlyPassword_123!

# Dedicated owner login for the application database. The init job creates this login as db_owner
# of AdventureWorksAIWorkspace only (no server-level rights, no access to AdventureWorks), so EF
# Core migrations work while staying least-privilege. The app no longer uses the sa account.
APP_DB_USER=awapp
APP_DB_PASSWORD=ChangeThis_AppDbPassword_123!

# Optional overrides for custom backup files. The init job auto-detects these by default.
# ADVENTUREWORKS_DATA_LOGICAL_NAME=AdventureWorks
# ADVENTUREWORKS_LOG_LOGICAL_NAME=AdventureWorks_log
